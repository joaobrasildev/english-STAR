{
  "name": "english-star",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build": "npm run build:frontend && npm run build:backend",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend run lint",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "test:backend": "npm --prefix backend run test:cov",
    "test:e2e": "npm --prefix backend run test:e2e",
    "test": "npm run test:backend && npm run test:e2e",
    "db:up": "docker compose up -d sqlserver",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f sqlserver",
    "db:ping": "npm --prefix backend run db:ping"
  }
}
